{
  "name": "@techseeding/kidplayai",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "src/api/server.js",
  "scripts": {
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true",
    "dev": "concurrently \"pnpm start:api\" \"pnpm start:portal\"",
    "start:api": "node --env-file=.env --watch-path=src/api --inspect src/api/server.js",
    "start:portal": "pnpm --filter @techseeding/kidplayai-portal dev",
    "build:prod": "rm -rf dist && pnpm --filter @techseeding/kidplayai-portal build && mkdir -p dist/src && cp -r src/api dist/src/api && cp package.json pnpm-lock.yaml dist/",
    "build:docker": "pnpm build:prod && docker buildx build --platform linux/amd64 --load -t techseeding/kidplayai -f devops/Dockerfile .",
    "start:prod": "node --env-file=.env.production dist/src/api/server.js",
    "start:local:docker": "pnpm build:docker && docker rm -f kidplayai 2>/dev/null; docker run -d --name kidplayai -p 9515:80 --env-file .env.localdocker techseeding/kidplayai",
    "release": "pnpm build:docker && AWS_PROFILE=kpai pnpm -F @techseeding/kidplayai-deploy release",
    "db:generate": "dotenv -e .env -- drizzle-kit generate --config src/api/drizzle.config.js",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate --config src/api/drizzle.config.js",
    "db:studio": "dotenv -e .env -- drizzle-kit studio --config src/api/drizzle.config.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.1.0",
    "postgres": "^3.4.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["node-pty"]
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.1"
  }
}
