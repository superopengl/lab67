{
  "name": "lab67",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "src/api/server.js",
  "scripts": {
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:portal\"",
    "dev:api": "node --env-file=.env --watch-path=src/api src/api/server.js",
    "dev:portal": "pnpm --filter lab67-portal dev",
    "build": "pnpm --filter lab67-portal build",
    "start:prod": "node --env-file=.env.production src/api/server.js",
    "db:generate": "dotenv -e .env -- drizzle-kit generate --config src/api/drizzle.config.js",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate --config src/api/drizzle.config.js",
    "db:studio": "dotenv -e .env -- drizzle-kit studio --config src/api/drizzle.config.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.2",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.1.0",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.1"
  }
}
