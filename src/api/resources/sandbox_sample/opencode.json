{
    "$schema": "https://opencode.ai/config.json",
    "model": "deepseek/deepseek-v4-flash",
    "autoupdate": false,
    "enabled_providers": ["deepseek"],
    "disabled_providers": ["openai", "anthropic", "gemini", "openrouter"],
    "permission": {
        "read": {
            "index.html": "allow",
            "*": "deny"
        },
        "edit": {
            "index.html": "allow",
            "*": "deny"
        },
        "bash": {
            "*": "deny"
        },
        "external_directory": "deny",
        "doom_loop": "deny"
    },
    "mcp": {},
    "plugin": [],
    "provider": {
        "deepseek": {
            "options": {
                "apiKey": "{env:DEEPSEEK_API_KEY}"
            }
        }
    }
}