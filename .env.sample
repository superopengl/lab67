# Lab67 Environment Variables
# Copy this file to .env for local development or .env.production for production.

LAB67_DATABASE_URL=postgres://localhost:5432/lab67
LAB67_API_SERVICE_URL=http://localhost:9511
LAB67_JWT_SECRET=change-me-to-a-random-secret

# Claude Code sandbox LLM config
LAB67_SANDBOX_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
LAB67_SANDBOX_ANTHROPIC_AUTH_TOKEN=<your DeepSeek API Key>
LAB67_SANDBOX_ANTHROPIC_MODEL=deepseek-v4-pro[1m]
LAB67_SANDBOX_ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
LAB67_SANDBOX_ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
LAB67_SANDBOX_ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
LAB67_SANDBOX_CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash
LAB67_SANDBOX_CLAUDE_CODE_EFFORT_LEVEL=max