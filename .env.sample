# Lab4Kids Environment Variables
# Copy this file to .env for local development or .env.production for production.

L4K_DATABASE_URL=postgres://localhost:5432/lab4kids
L4K_API_SERVICE_URL=http://localhost:9511
L4K_JWT_SECRET=change-me-to-a-random-secret

# OpenCode sandbox LLM config (DeepSeek)
L4K_SANDBOX_DEEPSEEK_API_KEY=<your DeepSeek API Key>