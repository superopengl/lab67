# KidPlayAI Environment Variables
# Copy this file to .env for local development or .env.production for production.

KPAI_DATABASE_URL=postgres://localhost:5432/kidplayai
KPAI_API_PORT=9511
KPAI_PUBLIC_URL=http://localhost:9512
KPAI_JWT_SECRET=change-me-to-a-random-secret

# OpenCode sandbox LLM config (DeepSeek)
KPAI_SANDBOX_DEEPSEEK_API_KEY=<your DeepSeek API Key>